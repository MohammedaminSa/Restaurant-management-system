# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (use Render's Internal Database URL as DATABASE_URL)
DATABASE_URL=

# JWT Configuration — generate strong random strings for production
JWT_SECRET=change_this_to_a_random_secret
JWT_REFRESH_SECRET=change_this_to_a_different_random_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS — set to your Vercel frontend URL
CORS_ORIGIN=

# Frontend URL (used for QR code generation)
FRONTEND_URL=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Cloudinary (optional — for production image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
